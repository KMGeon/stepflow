{
  "name": "stepflow-monorepo",
  "version": "0.2.0",
  "description": "Declarative Puppeteer RPA batch runtime with Spring Batch-style metadata, restart, and execution history.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "stepflow-*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run check && npm run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "mysql2": "^3.11.0",
    "prettier": "^3.3.0",
    "puppeteer": "^24.0.0",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.8.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
