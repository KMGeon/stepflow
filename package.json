{
  "name": "@kmgeon/stepflow",
  "version": "0.2.0",
  "description": "Declarative Puppeteer RPA batch runtime with Spring Batch-style metadata, restart, and execution history. One install ships the engine, the parallel Puppeteer runtime, durable repositories, triggers, and test utilities.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KMGeon/stepflow.git"
  },
  "homepage": "https://github.com/KMGeon/stepflow#readme",
  "bugs": "https://github.com/KMGeon/stepflow/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./puppeteer": {
      "import": {
        "types": "./dist/puppeteer/index.d.ts",
        "default": "./dist/puppeteer/index.js"
      },
      "require": {
        "types": "./dist/puppeteer/index.d.cts",
        "default": "./dist/puppeteer/index.cjs"
      }
    },
    "./infrastructure": {
      "import": {
        "types": "./dist/infrastructure/index.d.ts",
        "default": "./dist/infrastructure/index.js"
      },
      "require": {
        "types": "./dist/infrastructure/index.d.cts",
        "default": "./dist/infrastructure/index.cjs"
      }
    },
    "./integration": {
      "import": {
        "types": "./dist/integration/index.d.ts",
        "default": "./dist/integration/index.js"
      },
      "require": {
        "types": "./dist/integration/index.d.cts",
        "default": "./dist/integration/index.cjs"
      }
    },
    "./test": {
      "import": {
        "types": "./dist/test/index.d.ts",
        "default": "./dist/test/index.js"
      },
      "require": {
        "types": "./dist/test/index.d.cts",
        "default": "./dist/test/index.cjs"
      }
    },
    "./schema.sql": "./src/infrastructure/schema.sql",
    "./schema.sqlite.sql": "./src/infrastructure/schema.sqlite.sql",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/infrastructure/schema.sql",
    "src/infrastructure/schema.sqlite.sql",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run check && npm run build && changeset publish",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": ">=11",
    "mysql2": ">=3",
    "puppeteer": ">=22"
  },
  "peerDependencies": {
    "vitest": ">=2"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.8.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
