{
  "name": "@stepflow/core",
  "version": "0.2.0",
  "description": "Declarative Puppeteer RPA batch runtime — Job/Step/Flow builder, execution engine, metadata model, and the in-memory JobRepository.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KMGeon/stepflow.git",
    "directory": "stepflow-core"
  },
  "homepage": "https://github.com/KMGeon/stepflow#readme",
  "bugs": "https://github.com/KMGeon/stepflow/issues",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepack": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "puppeteer": ">=22"
  },
  "peerDependenciesMeta": {
    "puppeteer": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
