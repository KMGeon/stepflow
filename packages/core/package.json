{
  "name": "@stepflow/core",
  "version": "0.1.0",
  "description": "Declarative Puppeteer RPA batch runtime — Job/Step/Flow builder, execution engine, metadata model, and the in-memory JobRepository.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "puppeteer": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
