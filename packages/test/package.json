{
  "name": "@stepflow/test",
  "version": "0.1.0",
  "description": "Test utilities for stepflow: the JobRepository contract suite and a Puppeteer Page test double.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@stepflow/core": "^0.1.0"
  },
  "peerDependencies": {
    "puppeteer": ">=22",
    "vitest": ">=2"
  },
  "publishConfig": {
    "access": "public"
  }
}
